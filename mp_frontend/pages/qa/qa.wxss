.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F7FA;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #E5E6EB;
}

.status-info {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.status-dot.online { background-color: #00B42A; }
.status-dot.offline { background-color: #F53F3F; }

.status-text {
  font-size: 24rpx;
  color: #86909C;
}

.action-btn {
  font-size: 24rpx;
  color: #165DFF;
}

/* 聊天列表 */
.chat-list {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

.message-item {
  display: flex;
  margin-bottom: 40rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.message-item.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #fff;
}

.msg-wrapper {
  max-width: 70%;
  margin: 0 20rpx;
}

.message-item.user .msg-wrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.content {
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.message-item.assistant .content {
  background-color: #fff;
  color: #1D2129;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.message-item.user .content {
  background-color: #165DFF;
  color: #fff;
  border-top-right-radius: 4rpx;
}

.term-highlight {
  color: #165DFF;
  font-weight: bold;
  text-decoration: underline;
}

.message-item.user .term-highlight {
  color: #fff;
  text-decoration: underline;
}

.time {
  font-size: 22rpx;
  color: #C9CDD4;
  margin-top: 10rpx;
}

/* 溯源 */
.citations {
  display: flex;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.cite-tag {
  font-size: 20rpx;
  color: #165DFF;
  background-color: rgba(22, 93, 255, 0.1);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
}

/* 加载动画 */
.loading-box {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 100rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #C9CDD4;
  border-radius: 50%;
  margin: 0 4rpx;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1.0); }
}

/* 输入框 */
.input-area {
  background-color: #fff;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #E5E6EB;
  transition: all 0.2s;
}

.input-area.active {
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
}

.tool-bar {
  display: flex;
  margin-bottom: 15rpx;
}

.tool-btn {
  display: flex;
  align-items: center;
  background-color: #F2F3F5;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.tool-btn text {
  font-size: 24rpx;
  color: #165DFF;
  margin-left: 8rpx;
}

.input-row {
  display: flex;
  align-items: flex-end;
}

.voice-btn {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.voice-btn image {
  width: 44rpx;
  height: 44rpx;
}

.input {
  flex: 1;
  background-color: #F2F3F5;
  border-radius: 12rpx;
  padding: 15rpx 20rpx;
  font-size: 30rpx;
  max-height: 200rpx;
}

.send-btn {
  width: 70rpx;
  height: 70rpx;
  background-color: #F2F3F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  transition: all 0.2s;
}

.send-btn.active {
  background-color: #165DFF;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 85%;
  max-height: 70%;
  background-color: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #E5E6EB;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-header .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1D2129;
}

.modal-header .close {
  font-size: 40rpx;
  color: #86909C;
  padding: 10rpx;
}

.modal-body {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
}

.cite-source {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx dashed #E5E6EB;
}

.cite-source .label {
  font-size: 26rpx;
  color: #86909C;
}

.cite-source .value {
  font-size: 26rpx;
  color: #1D2129;
  font-weight: 500;
}

.cite-source .page {
  font-size: 24rpx;
  color: #165DFF;
  margin-left: 10rpx;
}

.cite-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #4E5969;
}

.modal-footer {
  padding: 20rpx 30rpx 40rpx;
  display: flex;
}

.modal-footer button {
  flex: 1;
  margin: 0 10rpx;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
}

.btn-plain {
  background-color: #F2F3F5;
  color: #4E5969;
}

.btn-primary {
  background-color: #165DFF;
  color: #fff;
}
