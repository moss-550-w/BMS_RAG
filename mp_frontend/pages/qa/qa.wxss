.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F7FA;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #E5E6EB;
}

.status-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #86909C;
}

.status-item .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.status-item.online .dot {
  background-color: #00B42A;
}

.status-item.offline .dot {
  background-color: #F53F3F;
}

.clear-btn {
  font-size: 24rpx;
  color: #165DFF;
}

/* 聊天列表 */
.chat-list {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

.message-item {
  display: flex;
  margin-bottom: 40rpx;
}

.message-item.user {
  justify-content: flex-end;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.bubble-container {
  max-width: 75%;
  margin: 0 20rpx;
}

.bubble {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.user .bubble {
  background-color: #165DFF;
  color: #ffffff;
  border-top-right-radius: 2rpx;
}

.assistant .bubble {
  background-color: #ffffff;
  color: #1D2129;
  border-top-left-radius: 2rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.timestamp {
  font-size: 20rpx;
  color: #86909C;
  margin-top: 8rpx;
  text-align: left;
}

.user .timestamp {
  text-align: right;
}

/* 引用 */
.citations {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #E5E6EB;
}

.citation-item {
  font-size: 24rpx;
  color: #165DFF;
  margin-bottom: 8rpx;
}

/* 输入区 */
.input-area {
  background-color: #ffffff;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #E5E6EB;
}

.quick-actions {
  display: flex;
  margin-bottom: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #165DFF;
  background-color: rgba(22, 93, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.input-wrapper {
  display: flex;
  align-items: flex-end;
}

.input-box {
  flex: 1;
  background-color: #F2F3F5;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  max-height: 200rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background-color: #E5E6EB;
  color: #ffffff;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 8rpx;
  margin-left: 20rpx;
  font-size: 28rpx;
  transition: all 0.3s;
}

.send-btn.active {
  background-color: #165DFF;
}

.voice-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 20rpx;
  padding: 16rpx 0;
  border: 1rpx solid #E5E6EB;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #4E5969;
}

.voice-btn image {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

/* 弹窗样式 */
.citation-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  z-index: 1000;
}

.modal-content {
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
}

.close-icon {
  font-size: 40rpx;
  color: #86909C;
  padding: 10rpx;
}

.cite-info {
  margin-bottom: 24rpx;
}

.cite-source {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1D2129;
}

.cite-page {
  font-size: 24rpx;
  color: #86909C;
}

.cite-text-scroll {
  flex: 1;
  background-color: #F7F8FA;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 40rpx;
}

.cite-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #4E5969;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
}

.footer-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 1rpx solid #E5E6EB;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin: 0 10rpx;
}

.footer-btn.primary {
  background-color: #165DFF;
  color: #ffffff;
  border: none;
}

/* 加载动画 */
.dot-flashing {
  position: relative;
  width: 10px;
  height: 10px;
  border-radius: 5px;
  background-color: #165DFF;
  color: #165DFF;
  animation: dot-flashing 1s infinite linear alternate;
  animation-delay: .5s;
  margin: 0 15px;
}

.dot-flashing::before, .dot-flashing::after {
  content: '';
  display: inline-block;
  position: absolute;
  top: 0;
}

.dot-flashing::before {
  left: -15px;
  width: 10px;
  height: 10px;
  border-radius: 5px;
  background-color: #165DFF;
  color: #165DFF;
  animation: dot-flashing 1s infinite alternate;
  animation-delay: 0s;
}

.dot-flashing::after {
  left: 15px;
  width: 10px;
  height: 10px;
  border-radius: 5px;
  background-color: #165DFF;
  color: #165DFF;
  animation: dot-flashing 1s infinite alternate;
  animation-delay: 1s;
}

@keyframes dot-flashing {
  0% { background-color: #165DFF; }
  50%, 100% { background-color: #E5E6EB; }
}
