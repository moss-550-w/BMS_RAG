<view class="container">
  <!-- 顶部状态栏 -->
  <view class="status-bar">
    <view class="status-info">
      <view class="status-dot {{backendStatus}}"></view>
      <text class="status-text">{{backendStatus === 'online' ? '引擎已就绪' : '后端连接中...'}}</text>
    </view>
    <view class="actions">
      <text class="action-btn" bindtap="clearHistory">清空</text>
    </view>
  </view>

  <!-- 聊天区域 -->
  <scroll-view 
    class="chat-list" 
    scroll-y 
    scroll-into-view="{{scrollToId}}" 
    scroll-with-animation
    enhanced
    show-scrollbar="{{false}}"
  >
    <view class="message-item welcome">
      <image class="avatar" src="../../assets/ai_avatar.png" />
      <view class="content">
        <text>您好！我是 BMS 智能助理。您可以问我关于电池管理系统（BMS）的任何技术问题，例如 SOC 估算、均衡策略或故障诊断。</text>
      </view>
    </view>

    <block wx:for="{{messages}}" wx:key="id">
      <view class="message-item {{item.role}}">
        <image class="avatar" src="{{item.role === 'user' ? '../../assets/user_avatar.png' : '../../assets/ai_avatar.png'}}" />
        <view class="msg-wrapper">
          <view class="content">
            <rich-text nodes="{{item.content}}"></rich-text>
          </view>
          
          <!-- 溯源角标 -->
          <view class="citations" wx:if="{{item.citations && item.citations.length > 0}}">
            <view 
              class="cite-tag" 
              wx:for="{{item.citations}}" 
              wx:for-item="cite" 
              wx:key="index"
              bindtap="showCitation"
              data-cite="{{cite}}"
            >
              [{{index + 1}}]
            </view>
          </view>
          
          <view class="time">{{item.time}}</view>
        </view>
      </view>
    </block>
    
    <!-- 加载中占位 -->
    <view class="message-item assistant" wx:if="{{loading}}">
      <image class="avatar" src="../../assets/ai_avatar.png" />
      <view class="content loading-box">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
    </view>

    <view id="bottom-anchor" style="height: 20rpx;"></view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area {{isInputActive ? 'active' : ''}}">
    <view class="tool-bar">
      <view class="tool-btn" bindtap="rewriteQuery">
        <icon type="search" size="16" color="#165DFF"/>
        <text>润色建议</text>
      </view>
    </view>
    <view class="input-row">
      <view class="voice-btn" bindtouchstart="startVoice" bindtouchend="endVoice">
        <image src="../../assets/mic.png" mode="aspectFit"/>
      </view>
      <textarea 
        class="input" 
        placeholder="输入您的问题..." 
        value="{{inputValue}}"
        bindinput="onInput"
        bindfocus="onInputFocus"
        bindblur="onInputBlur"
        auto-height
        fixed
        cursor-spacing="20"
      />
      <view class="send-btn {{inputValue ? 'active' : ''}}" bindtap="sendMessage">
        <icon type="success_no_circle" size="20" color="{{inputValue ? '#fff' : '#ccc'}}"/>
      </view>
    </view>
  </view>

  <!-- 溯源弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal" catchtouchmove="stopBubble">
    <view class="modal-content" catchtap="stopBubble">
      <view class="modal-header">
        <text class="title">原文溯源</text>
        <view class="close" bindtap="closeModal">×</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="cite-source">
          <text class="label">来源：</text>
          <text class="value">{{activeCite.source || '未知文献'}}</text>
          <text class="page" wx:if="{{activeCite.page}}">P{{activeCite.page}}</text>
        </view>
        <view class="cite-text">
          <rich-text nodes="{{activeCite.content}}"></rich-text>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <button class="btn-plain" bindtap="copyCite">复制内容</button>
        <button class="btn-primary" bindtap="goToLiterature">查看文献</button>
      </view>
    </view>
  </view>
</view>
