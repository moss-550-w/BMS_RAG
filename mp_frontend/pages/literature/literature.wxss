.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F7FA;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.search-input-wrap {
  flex: 1;
  height: 72rpx;
  background-color: #F2F3F5;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.search-input {
  flex: 1;
  margin-left: 15rpx;
  font-size: 28rpx;
}

.search-btn {
  font-size: 28rpx;
  color: #165DFF;
  padding: 0 20rpx 0 30rpx;
  font-weight: 500;
}

/* 统计 */
.stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  font-size: 24rpx;
  color: #86909C;
}

.sort-btn {
  display: flex;
  align-items: center;
}

.sort-btn image {
  width: 24rpx;
  height: 24rpx;
  margin-right: 6rpx;
}

/* 列表 */
.doc-list {
  flex: 1;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.doc-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.doc-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
}

.doc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.doc-name {
  font-size: 30rpx;
  color: #1D2129;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 10rpx;
}

.doc-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #86909C;
}

.doc-meta .dot {
  margin: 0 10rpx;
}

.arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 20rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #C9CDD4;
}
