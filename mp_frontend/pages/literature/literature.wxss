.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F7FA;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #E5E6EB;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background-color: #F2F3F5;
  border-radius: 36rpx;
  padding: 0 30rpx 0 70rpx;
  font-size: 26rpx;
  margin-left: -50rpx; /* 为icon腾出空间 */
}

.search-bar icon {
  position: relative;
  left: 20rpx;
  z-index: 1;
}

.filter-btn {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
  font-size: 26rpx;
  color: #4E5969;
}

.filter-btn image {
  width: 24rpx;
  height: 24rpx;
  margin-left: 8rpx;
}

/* 列表 */
.lib-list {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

.lib-card {
  background-color: #ffffff;
  padding: 24rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.lib-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(22, 93, 255, 0.05);
  border-radius: 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
}

.lib-icon image {
  width: 48rpx;
  height: 48rpx;
}

.lib-info {
  flex: 1;
  overflow: hidden;
}

.lib-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D2129;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.lib-meta {
  display: flex;
  font-size: 24rpx;
  color: #86909C;
}

.lib-author {
  margin-right: 20rpx;
}

.arrow image {
  width: 32rpx;
  height: 32rpx;
}

.stats-info {
  text-align: center;
  font-size: 24rpx;
  color: #86909C;
  padding: 40rpx 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  color: #86909C;
  font-size: 28rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

/* 详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  z-index: 1000;
}

.modal-content {
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
}

.close-icon {
  font-size: 40rpx;
  color: #86909C;
  padding: 10rpx;
}

.paper-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1D2129;
  line-height: 1.5;
  margin-bottom: 30rpx;
}

.paper-meta {
  background-color: #F7F8FA;
  padding: 24rpx;
  border-radius: 8rpx;
  margin-bottom: 40rpx;
}

.meta-item {
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.meta-item:last-child {
  margin-bottom: 0;
}

.meta-item .label {
  color: #86909C;
}

.meta-item .value {
  color: #1D2129;
}

.meta-item .value.highlight {
  color: #00B42A;
  font-weight: 500;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.fragments {
  flex: 1;
  overflow-y: auto;
  margin-bottom: 40rpx;
}

.fragment-item {
  border-left: 4rpx solid #165DFF;
  padding: 16rpx 20rpx;
  background-color: rgba(22, 93, 255, 0.02);
  margin-bottom: 20rpx;
}

.fragment-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #4E5969;
  display: block;
}

.fragment-meta {
  font-size: 22rpx;
  color: #86909C;
  margin-top: 12rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
}

.footer-btn {
  flex: 1;
  height: 88rpx;
  background-color: #ffffff;
  border: 1rpx solid #E5E6EB;
  border-radius: 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  margin: 0 !important;
}

.footer-btn.primary {
  background-color: #165DFF;
  color: #ffffff;
  border: none;
}
