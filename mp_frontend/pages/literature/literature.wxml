<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <icon type="search" size="14" color="#86909C"/>
      <input 
        class="search-input" 
        placeholder="搜索文献名称..." 
        value="{{searchQuery}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
    </view>
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <!-- 统计信息 -->
  <view class="stats">
    <text>共找到 {{total}} 份文献</text>
    <view class="sort-btn">
      <image src="../../assets/sort.png" mode="aspectFit"/>
      <text>按时间</text>
    </view>
  </view>

  <!-- 文献列表 -->
  <scroll-view class="doc-list" scroll-y refresher-enabled bindrefresherrefresh="onPullDownRefresh" refresher-triggered="{{loading}}">
    <block wx:if="{{docs.length > 0}}">
      <view 
        class="doc-item" 
        wx:for="{{docs}}" 
        wx:key="name" 
        bindtap="viewDoc" 
        data-doc="{{item}}"
      >
        <image class="doc-icon" src="../../assets/pdf_icon.png" mode="aspectFit"/>
        <view class="doc-info">
          <text class="doc-name">{{item.name}}</text>
          <view class="doc-meta">
            <text>{{item.type}}</text>
            <text class="dot">·</text>
            <text>{{item.size}}</text>
            <text class="dot">·</text>
            <text>{{item.mtime}}</text>
          </view>
        </view>
        <image class="arrow" src="../../assets/arrow_right.png" mode="aspectFit"/>
      </view>
    </block>

    <view class="empty-state" wx:else>
      <image src="../../assets/empty.png" mode="aspectFit"/>
      <text>未找到相关文献</text>
    </view>
    
    <view style="height: 40rpx;"></view>
  </scroll-view>
</view>
