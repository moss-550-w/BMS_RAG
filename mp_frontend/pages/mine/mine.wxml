<view class="container">
  <!-- 个人信息卡片 -->
  <view class="user-card">
    <image class="user-avatar" src="../../assets/user_avatar.png" mode="aspectFill"/>
    <view class="user-info">
      <text class="user-name">BMS 工程师</text>
      <text class="user-tag">技术专家</text>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-row">
    <view class="stats-item" bindtap="viewHistory">
      <text class="num">{{historyCount}}</text>
      <text class="label">历史问答</text>
    </view>
    <view class="stats-item" bindtap="viewCollections">
      <text class="num">{{collectCount}}</text>
      <text class="label">收藏文献</text>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="settings-group">
    <view class="group-title">系统配置</view>
    
    <view class="setting-item">
      <view class="label-wrap">
        <text class="label">向量引擎 (Embedding)</text>
        <text class="sub-label">切换不同的模型服务商</text>
      </view>
      <picker bindchange="onProviderChange" value="{{providerIndex}}" range="{{providers}}">
        <view class="picker-val">
          {{providers[providerIndex]}}
          <image class="arrow" src="../../assets/arrow_right.png"/>
        </view>
      </picker>
    </view>

    <view class="setting-item">
      <view class="label-wrap">
        <text class="label">检索条数 (Top-K)</text>
        <text class="sub-label">每轮检索召回的文档分块数</text>
      </view>
      <slider 
        class="slider" 
        min="1" 
        max="10" 
        value="{{topK}}" 
        show-value 
        activeColor="#165DFF" 
        bindchange="onTopKChange"
      />
    </view>

    <view class="setting-item">
      <view class="label-wrap">
        <text class="label">二次重排序 (Rerank)</text>
        <text class="sub-label">提升检索结果的相关度</text>
      </view>
      <switch checked="{{rerank}}" color="#165DFF" bindchange="onRerankChange"/>
    </view>
  </view>

  <view class="settings-group">
    <view class="group-title">系统维护</view>
    <view class="menu-item" bindtap="rebuildIndex">
      <text class="label">重建向量索引</text>
      <image class="arrow" src="../../assets/arrow_right.png"/>
    </view>
    <view class="menu-item" bindtap="showHelp">
      <text class="label">使用帮助</text>
      <image class="arrow" src="../../assets/arrow_right.png"/>
    </view>
  </view>

  <view class="version">Version 1.0.0 (Beta)</view>
</view>
