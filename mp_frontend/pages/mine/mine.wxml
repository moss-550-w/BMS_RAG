<view class="container">
  <!-- 用户信息 -->
  <view class="user-header">
    <view class="user-info">
      <view class="user-avatar">
        <image src="/assets/user_avatar.png" mode="aspectFill"></image>
      </view>
      <view class="user-text">
        <view class="username">BMS 研究员</view>
        <view class="user-tag">专业版用户</view>
      </view>
    </view>
    <view class="header-stats">
      <view class="stat-item">
        <text class="num">{{historyCount}}</text>
        <text class="label">对话历史</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="num">{{collectCount}}</text>
        <text class="label">我的收藏</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <scroll-view class="menu-list" scroll-y>
    <view class="menu-group">
      <view class="group-title">系统配置</view>
      <view class="menu-item">
        <view class="item-left">
          <text>向量引擎</text>
        </view>
        <view class="item-right">
          <picker bindchange="onProviderChange" value="{{providerIndex}}" range="{{providers}}">
            <view class="picker-value">{{providers[providerIndex]}}</view>
          </picker>
          <image class="arrow" src="/assets/arrow_right.png"></image>
        </view>
      </view>
      <view class="menu-item no-border">
        <view class="item-left">
          <text>检索数量 (Top-K)</text>
        </view>
        <view class="item-right">
          <slider class="topk-slider" min="1" max="10" value="{{topK}}" show-value bindchange="onTopKChange" activeColor="#165DFF" />
        </view>
      </view>
      <view class="menu-item">
        <view class="item-left">
          <text>重排序 (Rerank)</text>
        </view>
        <view class="item-right">
          <switch checked="{{rerank}}" color="#165DFF" bindchange="onRerankChange" />
        </view>
      </view>
    </view>

    <view class="menu-group">
      <view class="group-title">数据管理</view>
      <view class="menu-item" bindtap="viewHistory">
        <view class="item-left">
          <text>对话历史</text>
        </view>
        <view class="item-right">
          <image class="arrow" src="/assets/arrow_right.png"></image>
        </view>
      </view>
      <view class="menu-item" bindtap="viewCollections">
        <view class="item-left">
          <text>我的收藏</text>
        </view>
        <view class="item-right">
          <image class="arrow" src="/assets/arrow_right.png"></image>
        </view>
      </view>
    </view>

    <view class="menu-group">
      <view class="group-title">关于</view>
      <view class="menu-item">
        <view class="item-left">
          <text>系统版本</text>
        </view>
        <view class="item-right">
          <text class="value">V1.0.0</text>
        </view>
      </view>
      <view class="menu-item" bindtap="showHelp">
        <view class="item-left">
          <text>使用帮助</text>
        </view>
        <view class="item-right">
          <image class="arrow" src="/assets/arrow_right.png"></image>
        </view>
      </view>
    </view>
    
    <view class="logout-btn" bindtap="rebuildIndex">重建向量索引</view>
    <view class="version-info">最后更新: 2026-04-28</view>
  </scroll-view>
</view>
