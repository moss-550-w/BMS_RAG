.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F7FA;
}

/* 用户头部 */
.user-header {
  background-color: #165DFF;
  padding: 60rpx 40rpx 40rpx;
  color: #ffffff;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  overflow: hidden;
  margin-right: 30rpx;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-tag {
  font-size: 22rpx;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.header-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 30rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-item .num {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.stat-item .label {
  font-size: 24rpx;
  opacity: 0.8;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background-color: rgba(255, 255, 255, 0.2);
}

/* 菜单列表 */
.menu-list {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

.menu-group {
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.group-title {
  padding: 24rpx 30rpx 12rpx;
  font-size: 24rpx;
  color: #86909C;
  background-color: #ffffff;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F2F3F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.no-border {
  border-bottom: none;
}

.item-left {
  font-size: 28rpx;
  color: #1D2129;
}

.item-right {
  display: flex;
  align-items: center;
}

.picker-value {
  font-size: 28rpx;
  color: #165DFF;
}

.topk-slider {
  width: 300rpx;
  margin: 0;
}

.arrow {
  width: 28rpx;
  height: 28rpx;
  margin-left: 10rpx;
}

.value {
  font-size: 28rpx;
  color: #86909C;
}

.logout-btn {
  margin: 40rpx 20rpx 20rpx;
  height: 88rpx;
  background-color: #ffffff;
  color: #F53F3F;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.version-info {
  text-align: center;
  font-size: 22rpx;
  color: #C9CDD4;
  padding: 40rpx 0;
}
