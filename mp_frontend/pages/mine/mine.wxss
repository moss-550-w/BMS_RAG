.container {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding-bottom: 40rpx;
}

/* 个人信息 */
.user-card {
  background-color: #165DFF;
  padding: 60rpx 40rpx 100rpx;
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-right: 30rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.user-tag {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  background-color: rgba(255,255,255,0.15);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 统计 */
.stats-row {
  display: flex;
  background-color: #fff;
  margin: -40rpx 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid #F2F3F5;
}

.stats-item:last-child {
  border-right: none;
}

.stats-item .num {
  font-size: 36rpx;
  font-weight: bold;
  color: #1D2129;
  margin-bottom: 6rpx;
}

.stats-item .label {
  font-size: 24rpx;
  color: #86909C;
}

/* 设置组 */
.settings-group {
  background-color: #fff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.group-title {
  padding: 24rpx 30rpx 10rpx;
  font-size: 24rpx;
  color: #86909C;
}

.setting-item, .menu-item {
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #F2F3F5;
}

.setting-item:last-child, .menu-item:last-child {
  border-bottom: none;
}

.label-wrap {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.label {
  font-size: 30rpx;
  color: #1D2129;
}

.sub-label {
  font-size: 22rpx;
  color: #86909C;
  margin-top: 6rpx;
}

.picker-val {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #4E5969;
}

.arrow {
  width: 28rpx;
  height: 28rpx;
  margin-left: 10rpx;
  opacity: 0.3;
}

.slider {
  flex: 1;
  margin-left: 40rpx;
}

.version {
  text-align: center;
  font-size: 24rpx;
  color: #C9CDD4;
  margin-top: 60rpx;
}
